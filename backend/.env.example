# Deriv API Configuration
DERIV_API_URL=wss://ws.binaryws.com/websockets/v3
DERIV_APP_ID=your_app_id_here
DERIV_API_KEY=your_api_key_here

# Database
DATABASE_URL=mongodb://localhost:27017/dollarsmaster
# For PostgreSQL: postgresql://user:password@localhost:5432/dollarsmaster
DATABASE_TYPE=mongodb

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# AI Model
MODEL_PATH=./ai-engine/models/trading_model.h5
PREDICTION_CONFIDENCE_THRESHOLD=0.75
RETRAINING_INTERVAL=86400

# Logging
LOG_LEVEL=info

# Trading Settings
MAX_DAILY_LOSS=1000
MAX_CONCURRENT_TRADES=5
MIN_TRADE_SIZE=1
MAX_TRADE_SIZE=1000